AWSTemplateFormatVersion: '2010-09-09'
Description: darth-infra root stack for {{ project_name }}

Parameters:
  ProjectName:
    Type: String
    Default: {{ project_name }}
  EnvironmentName:
    Type: String
  VpcId:
    Type: AWS::EC2::VPC::Id
  VpcCidr:
    Type: String
  PrivateSubnetIds:
    Type: CommaDelimitedList
  PublicSubnetIds:
    Type: CommaDelimitedList
  AlbMode:
    Type: String
    AllowedValues: [shared, dedicated]
    Default: {{ alb.mode.value }}
  SharedAlbListenerArn:
    Type: String
    Default: ''
  SharedAlbSecurityGroupId:
    Type: String
    Default: ''
  SharedAlbDnsName:
    Type: String
    Default: ''
  CertificateArn:
    Type: String
    Default: '{{ alb.certificate_arn or "" }}'
  ClusterDomain:
    Type: String
    Default: '{{ alb.domain or "" }}'
{% if has_rds %}
  RdsSnapshotIdentifier:
    Type: String
    Default: ''
  RdsInstanceType:
    Type: String
    Default: {{ rds.instance_type }}
{% endif %}
{% if has_service_discovery %}
  ExistingCloudMapNamespaceId:
    Type: String
    Default: ''
{% endif %}
{% for secret in secrets if secret.source.value not in ['generate', 'rds'] %}
  EnvSecretArn{{ secret.name | replace('_', '') | replace('-', '') }}:
    Type: String
{% endfor %}

Conditions:
  IsProd: !Equals [!Ref EnvironmentName, prod]
  UseDedicatedAlb: !Equals [!Ref AlbMode, dedicated]
  HasCertificate: !Not [!Equals [!Ref CertificateArn, '']]
  UseDedicatedAlbWithCert: !And [!Condition UseDedicatedAlb, !Condition HasCertificate]
  UseDedicatedAlbNoCert: !And [!Condition UseDedicatedAlb, !Not [!Condition HasCertificate]]
{% if has_rds %}
  HasRdsSnapshot: !Not [!Equals [!Ref RdsSnapshotIdentifier, '']]
{% endif %}
{% if has_service_discovery %}
  HasExistingCloudMapNamespace: !Not [!Equals [!Ref ExistingCloudMapNamespaceId, '']]
  CreateServiceNamespace: !Equals [!Ref ExistingCloudMapNamespaceId, '']
{% endif %}

Resources:
  EcsCluster:
    Type: AWS::ECS::Cluster
    Properties:
      ClusterName: !Sub '${ProjectName}-${EnvironmentName}'
      ClusterSettings:
        - Name: containerInsights
          Value: enabled
      Tags:
        - Key: Project
          Value: !Ref ProjectName
        - Key: Environment
          Value: !Ref EnvironmentName
{% for key, value in tags.items() %}
        - Key: '{{ key }}'
          Value: '{{ value }}'
{% endfor %}

{% if has_service_discovery %}
  ServiceNamespace:
    Type: AWS::ServiceDiscovery::PrivateDnsNamespace
    Condition: CreateServiceNamespace
    Properties:
      Name: local
      Vpc: !Ref VpcId
      Tags:
        - Key: Project
          Value: !Ref ProjectName
        - Key: Environment
          Value: !Ref EnvironmentName
{% for key, value in tags.items() %}
        - Key: '{{ key }}'
          Value: '{{ value }}'
{% endfor %}
{% endif %}

  DedicatedAlb:
    Type: AWS::ElasticLoadBalancingV2::LoadBalancer
    Condition: UseDedicatedAlb
    Properties:
      Name: !Sub '${ProjectName}-${EnvironmentName}-alb'
      Scheme: internet-facing
      SecurityGroups:
        - !Ref DedicatedAlbSecurityGroup
      Subnets: !Ref PublicSubnetIds
      Type: application
      Tags:
        - Key: Project
          Value: !Ref ProjectName
        - Key: Environment
          Value: !Ref EnvironmentName
{% for key, value in tags.items() %}
        - Key: '{{ key }}'
          Value: '{{ value }}'
{% endfor %}

  DedicatedAlbSecurityGroup:
    Type: AWS::EC2::SecurityGroup
    Condition: UseDedicatedAlb
    Properties:
      GroupDescription: !Sub '${ProjectName}-${EnvironmentName} alb'
      VpcId: !Ref VpcId
      SecurityGroupIngress:
        - IpProtocol: tcp
          FromPort: 80
          ToPort: 80
          CidrIp: 0.0.0.0/0
        - !If
          - UseDedicatedAlbWithCert
          - IpProtocol: tcp
            FromPort: 443
            ToPort: 443
            CidrIp: 0.0.0.0/0
          - !Ref 'AWS::NoValue'
      Tags:
        - Key: Project
          Value: !Ref ProjectName
        - Key: Environment
          Value: !Ref EnvironmentName
{% for key, value in tags.items() %}
        - Key: '{{ key }}'
          Value: '{{ value }}'
{% endfor %}

  DedicatedAlbHttpListener:
    Type: AWS::ElasticLoadBalancingV2::Listener
    Condition: UseDedicatedAlb
    Properties:
      DefaultActions:
        - !If
          - UseDedicatedAlbWithCert
          - Type: redirect
            RedirectConfig:
              Protocol: HTTPS
              Port: '443'
              StatusCode: HTTP_301
          - Type: fixed-response
            FixedResponseConfig:
              StatusCode: '404'
              ContentType: text/plain
              MessageBody: Not Found
      LoadBalancerArn: !Ref DedicatedAlb
      Port: 80
      Protocol: HTTP

  DedicatedAlbHttpsListener:
    Type: AWS::ElasticLoadBalancingV2::Listener
    Condition: UseDedicatedAlbWithCert
    Properties:
      Certificates:
        - CertificateArn: !Ref CertificateArn
      DefaultActions:
        - Type: fixed-response
          FixedResponseConfig:
            StatusCode: '404'
            ContentType: text/plain
            MessageBody: Not Found
      LoadBalancerArn: !Ref DedicatedAlb
      Port: 443
      Protocol: HTTPS

{% if has_alb_cloudfront %}
  AlbCloudFront:
    Type: AWS::CloudFront::Distribution
    Properties:
      DistributionConfig:
        Enabled: true
{% if alb_cloudfront.comment %}
        Comment: '{{ alb_cloudfront.comment | replace("'", "''") }}'
{% endif %}
        PriceClass: {{ alb_cloudfront.price_class }}
{% if alb_cloudfront.custom_domain %}
        Aliases:
          - '{{ alb_cloudfront.custom_domain }}'
{% endif %}
        Origins:
          - DomainName: !If [UseDedicatedAlb, !GetAtt DedicatedAlb.DNSName, !Ref SharedAlbDnsName]
            Id: AlbOrigin
            CustomOriginConfig:
              HTTPPort: 80
              HTTPSPort: 443
              OriginProtocolPolicy: {{ 'https-only' if alb_cloudfront.origin_https_only else 'http-only' }}
{% if alb_cloudfront.certificate_arn %}
        ViewerCertificate:
          AcmCertificateArn: '{{ alb_cloudfront.certificate_arn }}'
          SslSupportMethod: sni-only
          MinimumProtocolVersion: TLSv1.2_2021
{% endif %}
        DefaultCacheBehavior:
          TargetOriginId: AlbOrigin
          ViewerProtocolPolicy: redirect-to-https
          AllowedMethods: [GET, HEAD, OPTIONS, PUT, PATCH, POST, DELETE]
          CachedMethods: [GET, HEAD, OPTIONS]
          Compress: true
          MinTTL: 0
          DefaultTTL: 0
          MaxTTL: 0
          ForwardedValues:
            QueryString: true
            Cookies:
              Forward: all
            Headers:
              - '*'
{% if alb_cloudfront.cached_behaviors %}
        CacheBehaviors:
{% for behavior in alb_cloudfront.cached_behaviors %}
          - PathPattern: '{{ behavior.path_pattern }}'
            TargetOriginId: AlbOrigin
            ViewerProtocolPolicy: redirect-to-https
            AllowedMethods: [GET, HEAD, OPTIONS, PUT, PATCH, POST, DELETE]
            CachedMethods: [GET, HEAD, OPTIONS]
            Compress: {{ 'true' if behavior.compress else 'false' }}
            MinTTL: {{ behavior.min_ttl_seconds }}
            DefaultTTL: {{ behavior.default_ttl_seconds }}
            MaxTTL: {{ behavior.max_ttl_seconds }}
            ForwardedValues:
{% if behavior.query_strings == 'none' %}
              QueryString: false
{% else %}
              QueryString: true
{% if behavior.query_strings == 'allowlist' and behavior.query_string_allowlist %}
              QueryStringCacheKeys:
{% for key in behavior.query_string_allowlist %}
                - '{{ key }}'
{% endfor %}
{% endif %}
{% endif %}
              Cookies:
{% if behavior.cookies == 'all' %}
                Forward: all
{% elif behavior.cookies == 'allowlist' %}
                Forward: whitelist
                WhitelistedNames:
{% for cookie in behavior.cookie_allowlist %}
                  - '{{ cookie }}'
{% endfor %}
{% else %}
                Forward: none
{% endif %}
              Headers:
                - Host
{% if behavior.forward_authorization_header %}
                - Authorization
{% endif %}
{% endfor %}
{% endif %}
      Tags:
        - Key: Project
          Value: !Ref ProjectName
        - Key: Environment
          Value: !Ref EnvironmentName
{% for key, value in tags.items() %}
        - Key: '{{ key }}'
          Value: '{{ value }}'
{% endfor %}
{% endif %}

{% for secret in secrets if secret.source.value == 'generate' %}
  Secret{{ secret.name | replace('_', '') | replace('-', '') }}:
    Type: AWS::SecretsManager::Secret
    Properties:
      Name: !Sub '/darth-infra/${ProjectName}/${EnvironmentName}/{{ secret.name }}'
      GenerateSecretString:
        PasswordLength: {{ secret.length }}
        ExcludePunctuation: true
      Tags:
        - Key: Project
          Value: !Ref ProjectName
        - Key: Environment
          Value: !Ref EnvironmentName
{% for key, value in tags.items() %}
        - Key: '{{ key }}'
          Value: '{{ value }}'
{% endfor %}
{% endfor %}

{% if has_s3 %}
{% for b in s3_buckets %}
{% if b.mode.value != 'existing' %}
  Bucket{{ b.name | replace('-', '') }}:
    Type: AWS::S3::Bucket
    Properties:
      BucketName: !Sub '${ProjectName}-${EnvironmentName}-{{ b.name }}'
{% if b.cors %}
      CorsConfiguration:
        CorsRules:
          - AllowedHeaders: ['*']
            AllowedMethods: [GET, PUT, POST, DELETE, HEAD]
            AllowedOrigins: ['*']
{% endif %}
      Tags:
        - Key: Project
          Value: !Ref ProjectName
        - Key: Environment
          Value: !Ref EnvironmentName
{% for key, value in tags.items() %}
        - Key: '{{ key }}'
          Value: '{{ value }}'
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}

{% if has_cloudfront %}
{% for b in s3_buckets if b.cloudfront and b.mode.value != 'existing' %}
  CloudFrontOac{{ b.name | replace('-', '') }}:
    Type: AWS::CloudFront::OriginAccessControl
    Properties:
      OriginAccessControlConfig:
        Name: !Sub '${ProjectName}-${EnvironmentName}-{{ b.name }}-oac'
        OriginAccessControlOriginType: s3
        SigningBehavior: always
        SigningProtocol: sigv4

  CloudFront{{ b.name | replace('-', '') }}:
    Type: AWS::CloudFront::Distribution
    Properties:
      DistributionConfig:
        Enabled: true
        Origins:
          - DomainName: !GetAtt Bucket{{ b.name | replace('-', '') }}.RegionalDomainName
            Id: S3{{ b.name | replace('-', '') }}Origin
            S3OriginConfig: {}
            OriginAccessControlId: !GetAtt CloudFrontOac{{ b.name | replace('-', '') }}.Id
        DefaultCacheBehavior:
          TargetOriginId: S3{{ b.name | replace('-', '') }}Origin
          ViewerProtocolPolicy: redirect-to-https
          AllowedMethods: [GET, HEAD, OPTIONS]
          CachedMethods: [GET, HEAD]
          Compress: true
          ForwardedValues:
            QueryString: false
            Cookies:
              Forward: none
        PriceClass: PriceClass_100
      Tags:
        - Key: Project
          Value: !Ref ProjectName
        - Key: Environment
          Value: !Ref EnvironmentName
{% for key, value in tags.items() %}
        - Key: '{{ key }}'
          Value: '{{ value }}'
{% endfor %}

  BucketPolicy{{ b.name | replace('-', '') }}:
    Type: AWS::S3::BucketPolicy
    Properties:
      Bucket: !Ref Bucket{{ b.name | replace('-', '') }}
      PolicyDocument:
        Version: '2012-10-17'
        Statement:
          - Sid: AllowCloudFrontRead
            Effect: Allow
            Principal:
              Service: cloudfront.amazonaws.com
            Action: s3:GetObject
            Resource: !Sub '${Bucket{{ b.name | replace('-', '') }}.Arn}/*'
            Condition:
              StringEquals:
                AWS:SourceArn: !Sub 'arn:aws:cloudfront::${AWS::AccountId}:distribution/${CloudFront{{ b.name | replace('-', '') }}}'
{% endfor %}
{% endif %}

{% for svc_ctx in services_ctx if not svc_ctx.svc.image %}
  EcrRepo{{ svc_ctx.name_pascal }}:
    Type: AWS::ECR::Repository
    Properties:
      RepositoryName: !Sub '${ProjectName}/${EnvironmentName}/{{ svc_ctx.name }}'
      Tags:
        - Key: Project
          Value: !Ref ProjectName
        - Key: Environment
          Value: !Ref EnvironmentName
{% for key, value in tags.items() %}
        - Key: '{{ key }}'
          Value: '{{ value }}'
{% endfor %}

{% endfor %}

{% if has_rds %}
  RdsCredentialsSecret:
    Type: AWS::SecretsManager::Secret
    Properties:
      Name: !Sub '${ProjectName}-${EnvironmentName}-rds-credentials'
      GenerateSecretString:
        SecretStringTemplate: '{"username": "{{ rds_master_username }}"}'
        GenerateStringKey: password
        PasswordLength: 32
        ExcludeCharacters: '"@/\'
      Tags:
        - Key: Project
          Value: !Ref ProjectName
        - Key: Environment
          Value: !Ref EnvironmentName
{% for key, value in tags.items() %}
        - Key: '{{ key }}'
          Value: '{{ value }}'
{% endfor %}

  RdsSecurityGroup:
    Type: AWS::EC2::SecurityGroup
    Properties:
      GroupDescription: !Sub '${ProjectName}-${EnvironmentName} rds'
      VpcId: !Ref VpcId
      Tags:
        - Key: Project
          Value: !Ref ProjectName
        - Key: Environment
          Value: !Ref EnvironmentName
{% for key, value in tags.items() %}
        - Key: '{{ key }}'
          Value: '{{ value }}'
{% endfor %}

  RdsSubnetGroup:
    Type: AWS::RDS::DBSubnetGroup
    Properties:
      DBSubnetGroupDescription: !Sub '${ProjectName}-${EnvironmentName} DB subnets'
      SubnetIds: !Ref PrivateSubnetIds
      Tags:
        - Key: Project
          Value: !Ref ProjectName
        - Key: Environment
          Value: !Ref EnvironmentName
{% for key, value in tags.items() %}
        - Key: '{{ key }}'
          Value: '{{ value }}'
{% endfor %}

  Database:
    Type: AWS::RDS::DBInstance
    DeletionPolicy: Snapshot
    Properties:
      DBInstanceIdentifier: !Sub '${ProjectName}-${EnvironmentName}-db'
      DBInstanceClass: !Ref RdsInstanceType
      Engine: postgres
      EngineVersion: '{{ rds.engine_version }}'
      MasterUsername: !Join ['', ['{{ "{{" }}resolve:secretsmanager:', !Ref RdsCredentialsSecret, ':SecretString:username{{ "}}" }}']]
      MasterUserPassword: !Join ['', ['{{ "{{" }}resolve:secretsmanager:', !Ref RdsCredentialsSecret, ':SecretString:password{{ "}}" }}']]
      AllocatedStorage: '{{ rds.allocated_storage_gb }}'
      BackupRetentionPeriod: {{ rds.backup_retention_days }}
      DBName: !If [HasRdsSnapshot, !Ref 'AWS::NoValue', '{{ rds.database_name }}']
      DBSnapshotIdentifier: !If [HasRdsSnapshot, !Ref RdsSnapshotIdentifier, !Ref 'AWS::NoValue']
      VPCSecurityGroups:
        - !Ref RdsSecurityGroup
      DBSubnetGroupName: !Ref RdsSubnetGroup
      PubliclyAccessible: false
      DeletionProtection: !If [IsProd, true, false]
      StorageType: gp3
      Tags:
        - Key: Project
          Value: !Ref ProjectName
        - Key: Environment
          Value: !Ref EnvironmentName
{% for key, value in tags.items() %}
        - Key: '{{ key }}'
          Value: '{{ value }}'
{% endfor %}

  RdsSecretAttachment:
    Type: AWS::SecretsManager::SecretTargetAttachment
    Properties:
      SecretId: !Ref RdsCredentialsSecret
      TargetId: !Ref Database
      TargetType: AWS::RDS::DBInstance
{% endif %}

{% for svc_ctx in services_ctx %}
  Service{{ svc_ctx.name_pascal }}:
    Type: AWS::CloudFormation::Stack
{% if svc_ctx.has_rds and not svc_ctx.svc.image %}
    DependsOn:
      - RdsSecretAttachment
      - EcrRepo{{ svc_ctx.name_pascal }}
{% elif svc_ctx.has_rds %}
    DependsOn: RdsSecretAttachment
{% elif not svc_ctx.svc.image %}
    DependsOn: EcrRepo{{ svc_ctx.name_pascal }}
{% endif %}
    Properties:
      TemplateURL: services/{{ svc_ctx.name }}.yaml
      Parameters:
        ProjectName: !Ref ProjectName
        EnvironmentName: !Ref EnvironmentName
        VpcId: !Ref VpcId
        VpcCidr: !Ref VpcCidr
        PrivateSubnetIds: !Join [",", !Ref PrivateSubnetIds]
        ClusterName: !Ref EcsCluster
        ClusterArn: !GetAtt EcsCluster.Arn
        ClusterDomain: !Ref ClusterDomain
        AlbListenerArn: !If [UseDedicatedAlb, !If [UseDedicatedAlbWithCert, !Ref DedicatedAlbHttpsListener, !Ref DedicatedAlbHttpListener], !Ref SharedAlbListenerArn]
        AlbSecurityGroupId: !If [UseDedicatedAlb, !Ref DedicatedAlbSecurityGroup, !Ref SharedAlbSecurityGroupId]
{% if has_service_discovery and svc_ctx.svc.enable_service_discovery %}        CloudMapNamespaceId: !If [HasExistingCloudMapNamespace, !Ref ExistingCloudMapNamespaceId, !Ref ServiceNamespace]
{% endif %}
{% if svc_ctx.has_rds %}
        RdsSecretArn: !Ref RdsCredentialsSecret
{% endif %}
{% for sec in svc_ctx.secret_params %}
{% set sec_name = sec.secret_name %}
{% set sec_source = sec.source %}
{% if sec_source == 'generate' %}
        {{ sec.param_name }}: !Ref Secret{{ sec_name | replace('_', '') | replace('-', '') }}
{% elif sec_source in ['env', 'existing'] %}
        {{ sec.param_name }}: !Ref EnvSecretArn{{ sec_name | replace('_', '') | replace('-', '') }}
{% endif %}
{% endfor %}
{% for s3 in svc_ctx.s3_vars %}
{% if s3.bucket_ref %}
        {{ s3.param_name }}: !Ref {{ s3.bucket_ref }}
        {{ s3.arn_param_name }}: !GetAtt {{ s3.bucket_ref }}.Arn
{% else %}
        {{ s3.param_name }}: '{{ s3.bucket_name_literal }}'
        {{ s3.arn_param_name }}: !Sub 'arn:aws:s3:::{{ s3.bucket_name_literal }}'
{% endif %}
{% if s3.cf_param_name %}
        {{ s3.cf_param_name }}: !Sub 'https://${CloudFront{{ s3.bucket_name | replace('-', '') }}.DomainName}'
{% endif %}
{% endfor %}
{% for cf in svc_ctx.cloudfront_vars %}
        {{ cf.param_name }}: !Sub 'https://${AlbCloudFront.DomainName}'
{% endfor %}
      Tags:
        - Key: Project
          Value: !Ref ProjectName
        - Key: Environment
          Value: !Ref EnvironmentName
{% for key, value in tags.items() %}
        - Key: '{{ key }}'
          Value: '{{ value }}'
{% endfor %}

{% endfor %}

{% if has_rds %}
{% for svc_ctx in services_ctx if svc_ctx.has_rds %}
  RdsIngressFrom{{ svc_ctx.name_pascal }}:
    Type: AWS::EC2::SecurityGroupIngress
    Properties:
      GroupId: !Ref RdsSecurityGroup
      IpProtocol: tcp
      FromPort: 5432
      ToPort: 5432
      SourceSecurityGroupId: !GetAtt Service{{ svc_ctx.name_pascal }}.Outputs.TaskSecurityGroupId

{% endfor %}
{% endif %}

  CustomOverrides:
    Type: AWS::CloudFormation::Stack
    Properties:
      TemplateURL: ../custom/overrides.yaml
Outputs:
  ClusterName:
    Value: !Ref EcsCluster
  StackEnvironment:
    Value: !Ref EnvironmentName
  AlbListenerArn:
    Value: !If [UseDedicatedAlb, !If [UseDedicatedAlbWithCert, !Ref DedicatedAlbHttpsListener, !Ref DedicatedAlbHttpListener], !Ref SharedAlbListenerArn]
{% if has_alb_cloudfront %}
  CloudFrontDistributionId:
    Value: !Ref AlbCloudFront
  CloudFrontDomainName:
    Value: !GetAtt AlbCloudFront.DomainName
  CloudFrontUrl:
    Value: !Sub 'https://${AlbCloudFront.DomainName}'
{% endif %}
